# eBPF TLS Tracer — systemd environment file
# Copy to /etc/tls-tracer/tls-tracer.env and customise as needed.
#
# All options are passed as a single TLS_TRACER_OPTS variable.
# Run `tls_tracer --help` for the full option reference.

# Default: JSON output with verbose logging
TLS_TRACER_OPTS=-f json -v

# --- Common options (uncomment to enable) ---

# Filter to a specific process
#TLS_TRACER_OPTS=-f json -v -p 1234

# BoringSSL / Envoy (Apigee Hybrid, Istio)
#TLS_TRACER_OPTS=-f json -v -B /usr/local/bin/envoy

# Session aggregation with 60-second idle timeout
#TLS_TRACER_OPTS=-f json -v --aggregate --aggregate-timeout 60

# PCAP export (writes pcap-ng file alongside JSON output)
#TLS_TRACER_OPTS=-f json -v --pcap /var/log/tls-tracer/capture.pcapng

# Prometheus metrics endpoint on port 9090
#TLS_TRACER_OPTS=-f json -v --metrics-port 9090

# Traffic filtering: only public HTTPS traffic
#TLS_TRACER_OPTS=-f json -v --net include:public --proto include:https

# Headers-only mode (PCI-DSS / GDPR — no body capture)
#TLS_TRACER_OPTS=-f json -v --headers-only

# Custom ring buffer size (16 MB, for high-throughput nodes)
#TLS_TRACER_OPTS=-f json -v --ring-buffer-size 16

# Extra sanitisation patterns (space-separated, added to built-in redaction)
#TLS_TRACER_OPTS=-f json -v -s 'token=[^&]*' -s 'password=[^&]*'
